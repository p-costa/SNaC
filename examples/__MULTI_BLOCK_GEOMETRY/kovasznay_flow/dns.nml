&dns
cfl = .95, dtmax = 1.0e5, dt_f = -1.
visci = .025
nstep = 50000, time_max = 100., tw_max = 0.1
stop_type(1:3) = T, F, F
restart = F, is_overwrite_save = T, nsaves_max = 0
icheck = 10, iout0d = 10, iout1d = 0, iout2d = 0, iout3d = 100, isave = 200
bforce(1:3) = 0., 0., 0.
/

&hypre
hypre_solver_i = 1, hypre_tol = 1.e-4, hypre_maxiter = 50
/
